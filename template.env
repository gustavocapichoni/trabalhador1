# =========================================================================
# CONFIGURAÇÕES DO BOT DO INSTAGRAM - ARQUITETURA 2.0
# =========================================================================
# Renomeie este arquivo para ".env" e preencha os valores abaixo.
# Na Oracle Cloud (VPS), crie este arquivo na raiz do projeto:
#   nano /home/ubuntu/my-bot-instagram/.env

# =========================================================================
# 1. GOOGLE GEMINI API KEYS (Rotação Automática de até 5 chaves)
# =========================================================================
# Obtenha em: https://aistudio.google.com/
# O bot tentará a chave 1 primeiro. Se a cota acabar, passa para a 2, e assim por diante.
# Ao menos a GEMINI_API_KEY_1 é obrigatória. As demais são opcionais mas recomendadas.
# Cada chave gratuita tem cota de ~1500 chamadas/dia. Com 5 chaves = ~7500 chamadas/dia.
GEMINI_API_KEY_1=INSIRA_SUA_CHAVE_1_AQUI
GEMINI_API_KEY_2=INSIRA_SUA_CHAVE_2_AQUI
GEMINI_API_KEY_3=INSIRA_SUA_CHAVE_3_AQUI
GEMINI_API_KEY_4=INSIRA_SUA_CHAVE_4_AQUI
GEMINI_API_KEY_5=INSIRA_SUA_CHAVE_5_AQUI

# =========================================================================
# 2. API DE MÍDIA
# =========================================================================

# Pexels API Key (para buscar vídeos B-roll automaticamente)
# Obtenha em: https://www.pexels.com/api/
PEXELS_API_KEY=INSIRA_SUA_CHAVE_AQUI

# Unsplash API Access Key (para buscar imagens de fundo)
# Obtenha em: https://unsplash.com/developers
# Se deixado em branco, o bot usará fundos escuros sólidos de fallback.
UNSPLASH_ACCESS_KEY=INSIRA_SUA_CHAVE_AQUI

# =========================================================================
# 3. CREDENCIAIS DO INSTAGRAM (META GRAPH API)
# =========================================================================
# Token de Acesso de Longa Duração do Facebook/Meta Graph API
# Deve conter as permissões: instagram_basic, instagram_content_publish,
#                            pages_read_engagement, pages_show_list
# ATENÇÃO: Tokens de longa duração expiram em ~60 dias. O bot te avisa por e-mail.
IG_ACCESS_TOKEN=INSIRA_SEU_TOKEN_AQUI

# ID da Conta do Instagram Business / Creator
# (Não é o seu @ de login! É o ID numérico da conta comercial)
# Como obter: https://developers.facebook.com/docs/instagram-api/getting-started
IG_ACCOUNT_ID=INSIRA_SEU_ID_NUMERICO_AQUI

# ── Segunda conta (opcional) ──────────────────────────────────────────────────
# Preencha para que o bot publique o mesmo conteúdo em uma segunda conta.
# Deixe em branco para desativar a segunda conta.
IG_ACCESS_TOKEN_2=INSIRA_O_TOKEN_DA_SEGUNDA_CONTA_AQUI
IG_ACCOUNT_ID_2=INSIRA_O_ID_DA_SEGUNDA_CONTA_AQUI

# =========================================================================
# 4. MONITORAMENTO POR E-MAIL (SMTP)
# =========================================================================
# Usado para receber alertas de erro, confirmações de postagem e avisos de expiração de token.
# Recomendado: criar uma conta Gmail dedicada ao bot e gerar uma "Senha de App".
# Como gerar Senha de App do Gmail: https://support.google.com/accounts/answer/185833
SMTP_EMAIL=email_remetente_do_bot@gmail.com
SMTP_PASSWORD=sua_senha_de_aplicativo_google
NOTIFY_EMAIL=gugacapichoni8@gmail.com

# =========================================================================
# 5. EXPANSÃO DE REDES (YOUTUBE SHORTS)
# =========================================================================
# Habilita ou desabilita a postagem automática no YouTube Shorts
POSTAR_NO_YOUTUBE=False
